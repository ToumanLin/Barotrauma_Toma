	</Affliction>
	<Affliction identifier="Wf_SaltedFishAttack" type="" isbuff="true" limbspecific="false" indicatorlimb="Torso" maxstrength="500.016" showiconthreshold="infinity" showicontoothersthreshold="infinity">
